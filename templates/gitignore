compilation.json

# MCP server registration — only needed on this machine
.mcp.json

# ── Commit these ─────────────────────────────────────────────────────────────
# The following files ARE safe and expected to commit. They are listed here
# (commented out) for reference so you know what to `git add`:
#
# claims.json              — your evidence database (the sprint's source of truth)
# CLAUDE.md                — AI assistant configuration for this sprint
# AGENTS.md                — universal AI instructions
# .claude/commands/wheat/  — slash commands for Claude Code
# output/                  — compiled artifacts (briefs, dashboards, presentations)
# research/                — topic explainers
# prototypes/              — working proof-of-concepts
# evidence/                — evaluation results
